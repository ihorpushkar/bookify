# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL) — used from Phase 1
# Local: docker compose up -d
DATABASE_URL="postgresql://bookify:bookify@localhost:5432/bookify"

# JWT — used from Phase 1
JWT_SECRET=change-me-to-a-random-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Email — optional in dev (uses Ethereal test inbox if SMTP not set)
EMAIL_FROM="Bookify <noreply@bookify.test>"
# Production / custom SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
